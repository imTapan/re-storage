{
  "name": "@imtapan/re-storage",
  "description": "A simple and lightweight library for managing local storage in JavaScript applications.",
  "version": "1.0.1",
  "type": "module",
  "author": {
    "name": "imTapan"
  },
  "main": "dist/re-storage.umd.js",
  "module": "dist/re-storage.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/re-storage.es.js",
      "require": "./dist/re-storage.umd.js"
    }
  },
  "scripts": {
    "build": "tsc && vite build",
    "publish": "npm publish --access=public"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "^6.3.1"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
